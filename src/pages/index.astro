---
import Layout from '../layouts/Layout.astro';

// Replaced with User's Real Projects
const projects = [
  {
    title: "Angonku.id",
    description: "Platform manajemen peternakan ayam broiler digital. Memantau FCR, IP Score, dan mortality rate secara real-time. Dilengkapi jadwal pemeliharaan otomatis, rekomendasi pakan, integrasi cuaca, push notification FCM, dan laporan PDF bankable untuk pengajuan KUR.",
    tech: ["React.js", "Inertia.js", "Laravel", "PostgreSQL", "Supabase", "Docker", "Sentry"],
    liveUrl: "#",
    githubUrl: "https://github.com/Masykster/Angonku.id",
    color: "#FFE600", // Yellow
  },
  {
    title: "Stre4mit",
    description: "Aplikasi streaming film berbasis Next.js dengan App Router. Di-deploy langsung ke stre4mit.vercel.app — dapat diakses publik tanpa setup lokal.",
    tech: ["Next.js", "JavaScript", "Tailwind CSS", "App Router", "Vercel"],
    liveUrl: "https://stre4mit.vercel.app",
    githubUrl: "https://github.com/Masykster/Stre4mit",
    color: "#00E5FF", // Blue
  },
  {
    title: "DailyBit",
    description: "Gamified habit tracker dan daily diary mobile app. Mendukung tiga tipe habit, sistem streak, mood tracking, achievement, cloud sync real-time, dan notifikasi harian. Rilis resmi v1.0.0.",
    tech: ["Flutter", "Dart", "Firebase Auth", "Firebase FCM", "Isar DB"],
    liveUrl: "#",
    githubUrl: "https://github.com/Masykster/DailyBit",
    color: "#39FF14", // Green
  },
  {
    title: "EcoFlow",
    description: "Aplikasi web sustainability berbasis Laravel dengan REST API terdokumentasi menggunakan Postman collection (EcoStep API) dan CI/CD pipeline via GitHub Actions.",
    tech: ["Blade", "Tailwind CSS", "Laravel", "REST API", "GitHub Actions", "Postman"],
    liveUrl: "#",
    githubUrl: "https://github.com/Masykster/EcoFlow",
    color: "#FF6B00", // Orange
  },
  {
    title: "Starling's Coffee",
    description: "Website e-commerce kedai kopi modern. Fitur: katalog menu, keranjang belanja, checkout (delivery/pickup), loyalty points & rewards, admin dashboard, manajemen pesanan, dan dark mode. Proyek tim 3 orang.",
    tech: ["HTML", "CSS", "JavaScript", "PHP Native", "MySQL"],
    liveUrl: "#",
    githubUrl: "https://github.com/Masykster/starling-s-coffeev2",
    color: "#FFE600", // Yellow
  },
  {
    title: "Aschention",
    description: "Aplikasi web SPA full-stack dengan Vue.js sebagai frontend dan Laravel sebagai backend. Arsitektur modern dengan database seeder dan schema populate.",
    tech: ["Vue.js", "Tailwind CSS", "Laravel", "PHP", "MySQL"],
    liveUrl: "#",
    githubUrl: "https://github.com/Masykster/Ascention",
    color: "#00E5FF", // Blue
  },
  {
    title: "Cinevora",
    description: "Platform katalog dan informasi film berbasis Laravel dan Blade. Arsitektur MVC Laravel dengan server-side rendering menggunakan Blade templating engine.",
    tech: ["Blade", "CSS", "Laravel", "PHP", "MySQL"],
    liveUrl: "#",
    githubUrl: "https://github.com/Masykster/Cinevora",
    color: "#39FF14", // Green
  }
];

// Replaced with User's Tech Stack
const skillCategories = [
  {
    title: "Frontend & Mobile",
    color: "bg-[#FFE600]", // Yellow
    skills: [
      { name: "HTML5", icon: "html" },
      { name: "CSS3", icon: "css" },
      { name: "JavaScript", icon: "js" },
      { name: "TypeScript", icon: "ts" },
      { name: "React.js", icon: "react" },
      { name: "Next.js", icon: "next" },
      { name: "Vue.js", icon: "vue" },
      { name: "Inertia.js", icon: "inertia" },
      { name: "Tailwind CSS", icon: "tailwind" },
      { name: "Flutter", icon: "flutter" },
      { name: "Dart", icon: "dart" }
    ]
  },
  {
    title: "Backend & Database",
    color: "bg-[#39FF14]", // Green
    skills: [
      { name: "Laravel", icon: "laravel" },
      { name: "PHP", icon: "php" },
      { name: "Supabase", icon: "supabase" },
      { name: "Firebase", icon: "firebase" },
      { name: "MySQL", icon: "mysql" },
      { name: "PostgreSQL", icon: "postgres" }
    ]
  },
  {
    title: "DevOps & Tools",
    color: "bg-[#00E5FF]", // Blue
    skills: [
      { name: "Docker", icon: "docker" },
      { name: "Git & GitHub", icon: "git" },
      { name: "Vercel", icon: "vercel" },
      { name: "Postman", icon: "postman" },
      { name: "Sentry", icon: "sentry" }
    ]
  }
];

const timeline = [
  {
    period: "Agustus 2024 – Sekarang",
    role: "D4 Manajemen Informatika (GPA: 3.93 / 4.00)",
    company: "Universitas Negeri Surabaya",
    description: "Semester 5, aktif dalam pengembangan proyek berbasis web dan mobile serta anggota aktif kepanitiaan MI EXPO 2024 (Divisi Humas, Desember 2024)."
  },
  {
    period: "Agustus 2021 – Juli 2024",
    role: "Ilmu Pengetahuan Alam (IPA)",
    company: "SMA Negeri 13 Surabaya",
    description: "Menempuh pendidikan sekolah menengah atas dengan peminatan Ilmu Pengetahuan Alam secara aktif."
  }
];
---

<Layout title="Masykster | Web Developer Portfolio" description="Portofolio pribadi Masykster - Web Developer profesional dengan keahlian di Astro, React, dan gaya desain Neo-Brutalisme yang unik.">
  <main class="max-w-6xl mx-auto px-4 sm:px-6 md:px-8 py-4 sm:py-8 font-sans overflow-hidden">
    
    <!-- HEADER SECTION -->
    <header class="sticky top-4 z-50 mb-8 sm:mb-12 reveal-on-scroll reveal-in">
      <div class="neo-box bg-white flex items-center justify-between p-4 px-6 md:px-8">
        <a href="#" class="flex items-center space-x-2 text-xl sm:text-2xl font-extrabold tracking-wider font-heading hover:text-[#FF6B00] transition-colors">
          <span class="bg-[#FFE600] px-2.5 py-1 border-2 border-black inline-block transform -rotate-2">M</span>
          <span class="bg-[#00E5FF] px-2.5 py-1 border-2 border-black inline-block transform rotate-3 -ml-1">S</span>
        </a>
        
        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center space-x-6 lg:space-x-8 font-bold">
          <a href="#karya" class="hover:underline hover:text-[#FF6B00] transition-colors decoration-3 underline-offset-4">Karya</a>
          <a href="#keahlian" class="hover:underline hover:text-[#FF6B00] transition-colors decoration-3 underline-offset-4">Keahlian</a>
          <a href="#tentang" class="hover:underline hover:text-[#FF6B00] transition-colors decoration-3 underline-offset-4">Tentang</a>
          <a href="#kontak" class="hover:underline hover:text-[#FF6B00] transition-colors decoration-3 underline-offset-4">Kontak</a>
        </nav>

        <div>
          <a href="#kontak" class="neo-btn bg-[#FF6B00] text-white text-xs sm:text-sm px-4 py-2 sm:px-5 sm:py-2.5">
            Hubungi Saya
          </a>
        </div>
      </div>
    </header>

    <!-- HERO SECTION -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-6 sm:gap-8 mb-12 sm:mb-16 reveal-on-scroll reveal-in delay-75">
      <!-- Title & Intro (Left Side) -->
      <div class="lg:col-span-8 neo-box-lg bg-white p-6 sm:p-10 flex flex-col justify-between">
        <div>
          <div class="inline-block bg-[#39FF14] text-black font-extrabold text-xs sm:text-sm px-3 py-1.5 border-2 border-black mb-6 uppercase tracking-wider transform -rotate-1">
            Web Developer & Designer
          </div>
          <h1 class="text-3xl sm:text-5xl md:text-6xl font-black font-heading leading-[1.05] tracking-tight mb-6">
            Halo, Saya <span class="bg-[#FFE600] inline-block px-2 border-2 border-black my-1 transform -rotate-1">Abdullah Masykur</span> — Membuat Web Cepat &amp; Berbeda.
          </h1>
          <p class="text-base sm:text-lg md:text-xl font-medium text-gray-700 leading-relaxed mb-8 max-w-2xl">
            Saya adalah pengembang web profesional yang berfokus pada performa tinggi, aksesibilitas, dan antarmuka pengguna yang berani serta tidak konvensional.
          </p>
        </div>

        <div class="flex flex-wrap gap-4">
          <a href="#karya" class="neo-btn bg-[#FFE600] text-black px-6 py-3.5 sm:px-8 sm:py-4 text-sm sm:text-base font-extrabold">
            Lihat Portofolio
          </a>
          <a href="#" class="neo-btn bg-white text-black px-6 py-3.5 sm:px-8 sm:py-4 text-sm sm:text-base font-extrabold border-3 border-black">
            Unduh CV (PDF)
          </a>
        </div>
      </div>

      <!-- Quick Badges & Availability (Right Side) -->
      <div class="lg:col-span-4 flex flex-col gap-6 sm:gap-8">
        <!-- Status Box -->
        <div class="neo-box bg-[#00E5FF] p-6 sm:p-8 flex flex-col justify-between flex-1">
          <h2 class="text-xl sm:text-2xl font-black font-heading tracking-tight mb-4">Ketersediaan Kerja</h2>
          <div class="neo-box bg-white p-4 font-bold flex items-center justify-between">
            <span>Status</span>
            <span class="inline-flex items-center bg-[#39FF14] border-2 border-black px-2.5 py-1 text-xs">
              Tersedia 🟢
            </span>
          </div>
          <p class="text-sm font-semibold mt-4 text-gray-800">
            Terbuka untuk proyek freelance, kontrak, dan posisi penuh waktu. Let's build something unique!
          </p>
        </div>

        <!-- Tech Quick Box -->
        <div class="neo-box bg-[#FF6B00] text-white p-6 sm:p-8 flex-1">
          <h2 class="text-xl sm:text-2xl font-black font-heading tracking-tight mb-4">Fokus Utama</h2>
          <div class="flex flex-wrap gap-2 text-black text-xs font-extrabold">
            <span class="bg-white border-2 border-black px-2.5 py-1 transform rotate-1">Laravel</span>
            <span class="bg-white border-2 border-black px-2.5 py-1 transform -rotate-2">React</span>
            <span class="bg-white border-2 border-black px-2.5 py-1 transform rotate-2">Next.js</span>
            <span class="bg-white border-2 border-black px-2.5 py-1 transform -rotate-1">Flutter</span>
            <span class="bg-white border-2 border-black px-2.5 py-1">Tailwind</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SCROLL VELOCITY MARQUEE -->
    <div class="w-screen relative left-[50%] right-[50%] ml-[-50vw] mr-[-50vw] overflow-x-hidden my-14 sm:my-20 reveal-on-scroll">
      <div class="border-t-4 border-b-4 border-black bg-[#FFE600] py-4 sm:py-6 select-none transform -rotate-1 shadow-[0px_4px_0px_0px_rgba(0,0,0,1)]">
        <div class="marquee-track flex whitespace-nowrap overflow-hidden">
          <div class="marquee-content animate-marquee flex gap-12 text-2xl sm:text-4xl md:text-5xl font-black uppercase font-heading tracking-widest pr-12">
            <span>DESIGN // DEVELOP // OPTIMIZE // LAUNCH // INNOVATE // SPEED // ACCESSIBILITY //</span>
          </div>
          <div class="marquee-content animate-marquee flex gap-12 text-2xl sm:text-4xl md:text-5xl font-black uppercase font-heading tracking-widest pr-12" aria-hidden="true">
            <span>DESIGN // DEVELOP // OPTIMIZE // LAUNCH // INNOVATE // SPEED // ACCESSIBILITY //</span>
          </div>
        </div>
      </div>
    </div>

    <!-- PORTFOLIO / KARYA SECTION -->
    <section id="karya" class="mb-12 sm:mb-16 scroll-mt-24 reveal-on-scroll">
      <div class="flex items-center mb-8">
        <h2 class="text-3xl sm:text-4xl font-black font-heading bg-[#FFE600] px-4 py-2 border-3 border-black inline-block transform -rotate-1">
          Karya Pilihan
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
        {projects.map((project, idx) => (
          <article class={`neo-box-lg bg-white flex flex-col justify-between overflow-hidden group reveal-on-scroll delay-${(idx + 1) * 75}`}>
            {/* Visual Header */}
            <div class="h-48 border-b-3 border-black bg-gray-200 relative flex items-center justify-center p-6 overflow-hidden" style={`background-color: ${project.color}33`}>
              <div class="absolute inset-0 bg-[linear-gradient(to_right,#000_1px,transparent_1px),linear-gradient(to_bottom,#000_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] opacity-[0.07]"></div>
              
              <div class="w-3/4 h-32 border-3 border-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col p-3 transition-transform duration-300 group-hover:scale-105 group-hover:-translate-y-2">
                <div class="flex items-center space-x-1.5 border-b-2 border-black pb-1.5 mb-2">
                  <div class="w-2.5 h-2.5 rounded-full bg-red-500 border border-black"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-yellow-500 border border-black"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-green-500 border border-black"></div>
                </div>
                <div class="flex-1 bg-gray-50 flex items-center justify-center font-heading font-black text-[11px] sm:text-xs uppercase tracking-wide border border-black/20 text-center px-1">
                  {project.title}
                </div>
              </div>
            </div>

            {/* Content info */}
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <h3 class="text-xl sm:text-2xl font-black font-heading mb-3 tracking-tight">{project.title}</h3>
                <p class="text-sm font-semibold text-gray-700 mb-6 leading-relaxed">
                  {project.description}
                </p>
              </div>

              <div>
                <!-- Tech stack Tags -->
                <div class="flex flex-wrap gap-1.5 mb-6">
                  {project.tech.map((tag) => (
                    <span class="bg-gray-100 border border-black px-2 py-0.5 text-[10px] sm:text-xs font-bold text-gray-800">
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Links Buttons -->
                <div class="flex items-center space-x-3">
                  <a href={project.liveUrl} class="neo-btn bg-[#FFE600] text-black text-xs font-extrabold px-3 py-2 flex items-center space-x-1">
                    <span>Demo</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-[2.5]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  </a>
                  <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="neo-btn bg-white text-black text-xs font-extrabold px-3 py-2 flex items-center space-x-1 border-3 border-black">
                    <span>GitHub</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-[2.5]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- KEAHLIAN / SKILLS SECTION -->
    <section id="keahlian" class="mb-12 sm:mb-16 scroll-mt-24 reveal-on-scroll">
      <div class="flex items-center mb-8">
        <h2 class="text-3xl sm:text-4xl font-black font-heading bg-[#00E5FF] px-4 py-2 border-3 border-black inline-block transform rotate-1">
          Keahlian &amp; Teknologi
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
        {skillCategories.map((category, catIdx) => (
          <div class={`neo-box-lg bg-white overflow-hidden reveal-on-scroll delay-${catIdx * 100}`}>
            <div class={`${category.color} p-4 border-b-3 border-black`}>
              <h3 class="text-xl font-black font-heading tracking-tight text-black uppercase">
                {category.title}
              </h3>
            </div>
            <div class="p-6">
              <div class="grid grid-cols-2 gap-3.5">
                {category.skills.map((skill) => (
                  <div class="flex items-center space-x-2.5 p-2 border-2 border-black bg-gray-50 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:bg-[#FFE600]/10 transition-colors font-bold text-[11px] sm:text-xs">
                    {/* Render corresponding SVG Icon */}
                    {skill.icon === 'html' && (
                      <svg class="w-5 h-5 text-[#E34F26]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l8 2-1.5 14L12 22l-6.5-4L4 4z" />
                        <path d="M12 6h4l-.5 5H12" />
                        <path d="M8 8h8" />
                        <path d="M12 11H9.5l-.5 4.5 3 2 3-2" />
                      </svg>
                    )}
                    {skill.icon === 'css' && (
                      <svg class="w-5 h-5 text-[#1572B6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l8 2-1.5 14L12 22l-6.5-4L4 4z" />
                        <path d="M12 6h4l-.5 5H9.5" />
                        <path d="M12 11h4l-.5 5-3.5 2-3.5-2 .5-4.5" />
                      </svg>
                    )}
                    {skill.icon === 'js' && (
                      <svg class="w-5 h-5 text-[#F7DF1E]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <path d="M9 17v-2a2 2 0 0 1 4 0v4" />
                        <path d="M17 11h-4" />
                        <path d="M15 15v-4" />
                      </svg>
                    )}
                    {skill.icon === 'ts' && (
                      <svg class="w-5 h-5 text-[#3178C6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <path d="M8 7h4M10 7v10" />
                        <path d="M15 13a2 2 0 0 0 2-2 2 2 0 0 0-2-2h-1v6" />
                      </svg>
                    )}
                    {skill.icon === 'react' && (
                      <svg class="w-5 h-5 text-[#61DAFB]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(30 12 12)" />
                        <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(90 12 12)" />
                        <ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(150 12 12)" />
                        <circle cx="12" cy="12" r="1.5" />
                      </svg>
                    )}
                    {skill.icon === 'next' && (
                      <svg class="w-5 h-5 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M16 16L8 8M16 8v8" />
                      </svg>
                    )}
                    {skill.icon === 'vue' && (
                      <svg class="w-5 h-5 text-[#4FC08D]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 3l10 17L22 3" />
                        <path d="M6 3l6 10 6-10" />
                      </svg>
                    )}
                    {skill.icon === 'inertia' && (
                      <svg class="w-5 h-5 text-[#9553E6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 6h16M4 12h16M4 18h16" />
                        <path d="M8 6v12M16 6v12" />
                      </svg>
                    )}
                    {skill.icon === 'tailwind' && (
                      <svg class="w-5 h-5 text-[#38BDF8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3c-1.2 0-2.4.6-3 1.8C7.8 7.2 6.6 9 4.8 9c-1.2 0-2.4-.6-3-1.8C.6 4.8 1.8 3 3.6 3c1.2 0 2.4.6 3 1.8 1.2 2.4 2.4 4.2 4.2 4.2 1.2 0 2.4-.6 3-1.8 1.2-2.4 2.4-4.2 4.2-4.2 1.2 0 2.4.6 3 1.8 1.2 2.4 2.4 4.2 4.2 4.2 1.2 0 2.4-.6 3-1.8.6-1.2-1.2-3-3-3" />
                        <path d="M12 15c-1.2 0-2.4.6-3 1.8-1.2 2.4-2.4 4.2-4.2 4.2-1.2 0-2.4-.6-3-1.8.6-1.2 2.4-3 4.2-3 1.2 0 2.4.6 3 1.8 1.2 2.4 2.4 4.2 4.2 4.2 1.2 0 2.4-.6 3-1.8.6-1.2 2.4-3 4.2-3" />
                      </svg>
                    )}
                    {skill.icon === 'flutter' && (
                      <svg class="w-5 h-5 text-[#02569B]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2l-8 8 4 4 8-8z" />
                        <path d="M14 10L6 18l4 4 8-8z" />
                      </svg>
                    )}
                    {skill.icon === 'dart' && (
                      <svg class="w-5 h-5 text-[#00C4B4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l10 10-10 10L2 12z" />
                        <path d="M12 6l6 6-6 6-6-6z" />
                      </svg>
                    )}
                    {skill.icon === 'laravel' && (
                      <svg class="w-5 h-5 text-[#FF2D20]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16v16H4z" />
                        <path d="M4 12h16M12 4v16" />
                        <path d="M8 8h8v8H8z" />
                      </svg>
                    )}
