---
import Layout from '../layouts/Layout.astro';
import Builder from '../components/Builder.tsx';
---

<Layout>
  <main class="min-h-screen flex flex-col">
    <!-- Header Section -->
    <header class="border-b border-gray-800/80 bg-gray-950/80 backdrop-blur-md px-6 py-4 flex items-center justify-between sticky top-0 z-50">
      <div class="flex items-center space-x-3">
        <!-- SVG Logo resembling a glass bento grid block -->
        <div class="relative w-8 h-8 rounded-lg overflow-hidden border border-white/20 bg-white/5 flex items-center justify-center">
          <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/30 to-pink-500/30"></div>
          <div class="grid grid-cols-2 grid-rows-2 gap-1 w-4 h-4 z-10">
            <div class="bg-white/80 rounded-[2px] col-span-2"></div>
            <div class="bg-white/60 rounded-[2px]"></div>
            <div class="bg-white/40 rounded-[2px]"></div>
          </div>
        </div>
        <div>
          <h1 class="text-lg font-bold bg-gradient-to-r from-indigo-200 via-white to-pink-100 bg-clip-text text-transparent tracking-tight">
            GlassBento
          </h1>
          <p class="text-2xs text-gray-500 font-medium">Bento Grid & Glassmorphism Builder</p>
        </div>
      </div>
      
      <div class="flex items-center space-x-4">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-2xs font-semibold bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">
          v1.0 Client-Side
        </span>
        <a 
          href="https://github.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-xs text-gray-400 hover:text-white transition-colors flex items-center space-x-1"
        >
          <span>Docs</span>
        </a>
      </div>
    </header>

    <!-- Main Workspace React Island -->
    <div class="flex-1 flex flex-col">
      <Builder client:load />
    </div>

    <!-- Small Footer -->
    <footer class="py-4 border-t border-gray-900 bg-gray-950 text-center text-xs text-gray-600">
      <p>GlassBento UI Builder &bull; Built with Astro, React, and Zustand &bull; 100% Static & Private</p>
    </footer>
  </main>
</Layout>
