<script>
  const initializeAnimations = () => {
    let lastScrollY = window.scrollY;
    let scrollTimeout: any = null;
    
    // 1. Scroll Velocity Marquee
    const updateMarqueeSpeed = () => {
      const marquees = document.querySelectorAll('.animate-marquee');
      const currentScroll = window.scrollY;
      const diff = Math.abs(currentScroll - lastScrollY);
      
      if (diff > 2) {
        const speedFactor = Math.min(Math.max(diff / 8, 1), 6);
        marquees.forEach((marquee: any) => {
          marquee.style.animationDuration = `${25 / speedFactor}s`;
        });
        
        if (scrollTimeout) clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          marquees.forEach((marquee: any) => {
            marquee.style.animationDuration = '25s';
          });
        }, 150);
      }
      
      lastScrollY = currentScroll;
    };

    window.addEventListener('scroll', updateMarqueeSpeed, { passive: true });

    // 2. Intersection Observer for stagger fade-in reveal on scroll
    const revealElements = document.querySelectorAll('.reveal-on-scroll');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal-in');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.05,
      rootMargin: '0px 0px -40px 0px'
    });

    revealElements.forEach(el => observer.observe(el));
  };

  document.addEventListener('astro:page-load', initializeAnimations);
</script>
